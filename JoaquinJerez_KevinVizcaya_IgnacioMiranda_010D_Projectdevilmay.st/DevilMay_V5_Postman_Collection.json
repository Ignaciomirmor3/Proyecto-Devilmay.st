  "item": [
    {
      "name": "1. Catálogo (8081)",
      "item": [
        {
          "name": "Listar Todos los Productos",
          "request": {
            "method": "GET",
            "url": "http://localhost:8081/api/v1/productos"
          }
        },
        {
          "name": "Filtrar Productos (Query Params)",
          "request": {
            "method": "GET",
            "url": "http://localhost:8081/api/v1/productos?genero=MASCULINO&tipoPrenda=EXTERIOR"
          }
        },
        {
          "name": "Buscar Producto por ID",
          "request": {
            "method": "GET",
            "url": "http://localhost:8081/api/v1/productos/1"
          }
        },
        {
          "name": "Crear Producto",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombreProducto\": \"Chaqueta de Cuero Exclusiva\",\n  \"descripcionProducto\": \"Chaqueta edición limitada.\",\n  \"precioProducto\": 120000,\n  \"tallaProducto\": \"M\",\n  \"urlImagen\": \"http://img.com/chaqueta.png\",\n  \"genero\": \"UNISEX\",\n  \"tipoPrenda\": \"EXTERIOR\"\n}"
            },
            "url": "http://localhost:8081/api/v1/productos"
          }
        },
        {
          "name": "Actualizar Producto",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombreProducto\": \"Chaqueta de Cuero Modificada\",\n  \"descripcionProducto\": \"Chaqueta editada.\",\n  \"precioProducto\": 115000,\n  \"tallaProducto\": \"L\",\n  \"urlImagen\": \"http://img.com/chaqueta2.png\",\n  \"genero\": \"UNISEX\",\n  \"tipoPrenda\": \"EXTERIOR\"\n}"
            },
            "url": "http://localhost:8081/api/v1/productos/1"
          }
        },
        {
          "name": "Eliminar Producto",
          "request": {
            "method": "DELETE",
            "url": "http://localhost:8081/api/v1/productos/1"
          }
        }
      ]
    },
